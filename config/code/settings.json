{
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__gateway__*",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash",
      "Agent",
      "WebFetch",
      "WebSearch",
      "Bash(bash bench/bench_state.sh*)",
      "Bash(bash bench/run_modbus_experiment.sh*)",
      "Bash(bash bench/run_modbus_experiment_wired.sh*)",
      "Bash(bash bench/analyze_pcap.sh*)",
      "Bash(bash bench/push_cm4.sh*)",
      "Bash(python bench/uart_reader.py*)",
      "Bash(python bench/analyze_da30_timing.py*)",
      "Bash(python bench/analyze_da30_setup_requests.py*)",
      "Bash(python bench/analyze_chain_rtt.py*)",
      "Bash(python bench/analyze_fragments.py*)",
      "Bash(python bench/analyze_three_intervals.py*)",
      "Bash(python bench/parse_modbus_csv.py*)",
      "Bash(python bench/parse_relay_trace.py*)",
      "Bash(python bench/compile_session_summary.py*)",
      "Bash(powershell.exe -NoProfile*)",
      "PowerShell(Get-PnpDevice *)",
      "PowerShell(Get-CimInstance *)",
      "PowerShell(Get-Process *)",
      "PowerShell(Get-PSDrive *)",
      "PowerShell(Get-ItemProperty *)",
      "PowerShell(Get-Item *)",
      "PowerShell(Test-Path *)",
      "PowerShell($targets *)",
      "Bash(python client/moxa_loopback_test.py*)",
      "Bash(python client/modbus_direct_test.py*)",
      "Bash(python client/modbus_ftdi_test.py*)",
      "Bash(python client/test_spi_ping.py*)",
      "Bash(python client/test_all_slots.py*)",
      "Bash(python -m pytest client/test_g3_broker.py*)",
      "Bash(python client/test_g3_broker.py*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat /c/dev/claude-skills-suite/config/code/behavioral-reminders.bp.txt"
          },
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/session-prewarm.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/interagent-inbox-nudge.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat /c/dev/claude-skills-suite/config/code/behavioral-reminders.bp.txt"
          },
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/pre-compact-capture.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/search-before-act.sh"
          },
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/pre-commit-lint.sh"
          }
        ]
      },
      {
        "matcher": "mcp__gateway__memory_call|mcp__gateway__graph_call",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/search-before-memory.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/block-auto-memory.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/post-edit-complexity.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/post-edit-complexity.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/post-commit-memory-sync.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/dev/claude-skills-suite/hooks/session-end-summary.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "light",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  },
  "skills": [
    "C:\\dev\\claude-skills-suite\\skills"
  ]
}
